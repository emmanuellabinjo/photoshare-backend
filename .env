# ─── Azure Cosmos DB ──────────────────────────────────────────────────────────
COSMOS_CONNECTION_STRING=AccountEndpoint=https://YOUR_ACCOUNT.documents.azure.com:443/;AccountKey=YOUR_KEY==;
COSMOS_DATABASE=PhotoShareDB

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY==;EndpointSuffix=core.windows.net
STORAGE_CONTAINER_PHOTOS=photos
STORAGE_CONTAINER_THUMBNAILS=thumbnails

# ─── Azure AI Vision (Computer Vision) ───────────────────────────────────────
VISION_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com/
VISION_KEY=YOUR_COMPUTER_VISION_KEY

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
